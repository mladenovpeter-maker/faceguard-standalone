# Copy this file to `selfhost/.env` and fill in real values before running
# `docker compose -f selfhost/docker-compose.yml --env-file selfhost/.env up --build`

# Password for the Postgres container (also used to build DATABASE_URL).
POSTGRES_PASSWORD=change-me

# The camera worker logs in as an existing FaceGuard user (created via the
# admin UI's user management, or the default seeded admin) to call the
# recognitions API on behalf of your cameras.
CAMERA_WORKER_USERNAME=admin
CAMERA_WORKER_PASSWORD=change-me

# How often (ms) the worker grabs a fresh frame from each configured camera.
CAMERA_WORKER_POLL_INTERVAL_MS=5000

# Cloudflare Tunnel token (from Cloudflare Zero Trust > Networks > Tunnels).
# Lets you reach FaceGuard from outside your home network via your own domain,
# without opening any ports on your router. Never commit the real value.
CLOUDFLARE_TUNNEL_TOKEN=change-me
